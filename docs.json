              "develop/defining-graphs",
              "develop/debug"
            ]
          },
          {
            "group": "Deploy",
            "pages": [
              "deploy/deploying-the-interface",
              "deploy/deploying-the-backend"
            ]
          },
          {
            "group": "Guides and Best Practices",
            "pages": ["guides/data-handling", "guides/tips-best-practices"]
          }
        ]
      },
